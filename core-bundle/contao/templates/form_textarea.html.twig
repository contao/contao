{% extends '@Contao/form_row.html.twig' %}

{% block label %}
    {% if this.label %}
        <label for="ctrl_{{ this.id }}">
            {% if this.mandatory|default %}
                <span class="invisible">{{ this.mandatoryField }} </span>{{ this.label|insert_tag_html }}<span class="mandatory">*</span>
            {% else %}
                {{ this.label|insert_tag_html }}
            {% endif %}
        </label>
    {% endif %}
{% endblock %}

{% block field %}
    {% if hasErrors.invoke() %}
        <p class="error">{{ getErrorAsString.invoke() }}</p>
    {% endif %}

    {% set textarea_attributes = attrs(getAttributes.invoke()) %}

    <textarea{{ attrs()
        .set('name', this.name)
        .set('id', "ctrl_#{this.id}")
        .addClass('textarea')
        .set('rows', this.rows)
        .set('cols', this.cols)
        .set('aria-describedby', "help_ctrl_#{this.id}", this.help|default)
        .mergeWith(textarea_attributes)
        .setIfExists('placeholder', textarea_attributes.placeholder|default|insert_tag)
    }}>{{ this.value }}</textarea>

    {% if this.help|default %}
        <p class="help" id="help_ctrl_{{ this.id }}">{{ this.help|insert_tag_html }}</p>
    {% endif %}
{% endblock %}
