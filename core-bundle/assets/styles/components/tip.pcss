/* Tips */
.tl_tip {
    height: 15px;
    overflow: hidden;
    cursor: help;
    text-overflow: ellipsis;
    white-space: nowrap;
}

#tooltip {
    display: none;
    width: max-content;
    max-width: 80vw;
    position: absolute;
    top: 0;
    left: 0;
    padding: 6px 9px;
    border-radius: var(--border-radius);
    background: var(--invert-bg);
    z-index: 99;
    pointer-events: none;

    div {
        line-height: 1.3;
    }

    :is(div, a, span) {
        color: var(--invert-text);
    }
}
